/build/
/Testing/
/.cache/
**/__pycache__/
CMakeUserPresets.json
# Local symlink to build/compile_commands.json for clangd; recreated by
# anyone after cmake configure (see CMakeLists.txt).
/compile_commands.json

# Sandbox shadow placeholders: 0-byte read-only bind-mounts the
# Claude Code sandbox creates in the working tree to mask the
# corresponding paths in $HOME. Not real repo content; can't be
# rm'd while the sandbox holds them open.
/.bash_profile
/.bashrc
/.gitconfig
/.gitmodules
/.idea
/.mcp.json
/.profile
/.ripgreprc
/.vscode
/.zprofile
/.zshrc

# Local datasets / fixtures / renders — multi-GB, never committed.
/data/
/vids/
/tests/fixtures/*
/.claude/

# EXCEPTION: the multi-sensor sim generator is committed SOURCE (it produces
# the local fixtures on demand). Keep the generator package + its docs/pins
# tracked, while the venv, generated CSVs, checksums, and meta stay ignored.
!/tests/fixtures/sim_multisensor/
/tests/fixtures/sim_multisensor/*
!/tests/fixtures/sim_multisensor/generator/
!/tests/fixtures/sim_multisensor/README.md
!/tests/fixtures/sim_multisensor/requirements.txt
!/tests/fixtures/sim_multisensor/requirements.lock.txt
/tests/fixtures/sim_multisensor/generator/*
!/tests/fixtures/sim_multisensor/generator/*.py

# External reference implementations — read-only cross-check material
# (e.g. Garcia-Fernandez MTT MATLAB toolbox for PMBM port). Fetched per
# developer; never linked into the build. See docs/algorithms/pmbm-design.md.
/third_party/reference/
