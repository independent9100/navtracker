# Sandbox shadow placeholders: 0-byte read-only bind-mounts the
# Claude Code sandbox creates in the working tree to mask the
# corresponding paths in $HOME. Not real repo content; can't be
# rm'd while the sandbox holds them open.
/.bash_profile
/.bashrc
/.gitconfig
/.gitmodules
/.idea
/.mcp.json
/.profile
/.ripgreprc
/.vscode
/.zprofile
/.zshrc

# Local datasets / fixtures / renders — multi-GB, never committed.
/data/
/vids/
/tests/fixtures/
/.claude/

# Paywalled / copyrighted papers fetched locally — do not commit.
/1-s2.0-*.pdf

# External reference implementations — read-only cross-check material
# (e.g. Garcia-Fernandez MTT MATLAB toolbox for PMBM port). Fetched per
# developer; never linked into the build. See docs/algorithms/pmbm-design.md.
/third_party/reference/
